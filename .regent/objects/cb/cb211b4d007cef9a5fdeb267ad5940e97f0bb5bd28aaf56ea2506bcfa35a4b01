"# Online Judge - Docker Compose Configuration\n#\n# Services:\n#   - postgres: PostgreSQL database (port 5432)\n#   - redis: Redis cache/message queue (port 6379)\n#   - api: REST API service (port 3000)\n#   - frontend: Vite dev server (port 5173)\n#   - feature-gateway: Feature flag resolution service (port 3001)\n#   - judge-worker: Code execution service\n#   - llm-worker: LLM analysis worker (consumes from Redis Streams)\n#\n# Environment Variables Required for API:\n#   - DATABASE_URL=postgresql://postgres:postgres@localhost:5432/online_judge\n#   - REDIS_URL=redis://localhost:6379\n#   - JWT_SECRET=your-secret-key\n#\n# Usage:\n#   Start all services:\n#     docker compose up -d\n#\n#   Start specific service:\n#     docker compose up -d postgres redis\n#\n#   Stop services:\n#     docker compose down\n#\n#   Reset volumes (delete all data):\n#     docker compose down -v\n#\n#   View logs:\n#     docker compose logs -f [service]\n#\n#   Verify services are healthy:\n#     docker compose ps\n#\n# Development:\n#   Run API locally (without Docker):\n#     DATABASE_URL=postgresql://postgres:postgres@localhost:5432/online_judge \\\n#     REDIS_URL=redis://localhost:6379 \\\n#     JWT_SECRET=dev-secret \\\n#     cargo run --bin api\n#\n#   Run frontend locally:\n#     npm run dev\n\nservices:\n  postgres:\n    image: postgres:16-alpine\n    container_name: online-judge-postgres\n    restart: unless-stopped\n    environment:\n      POSTGRES_USER: postgres\n      POSTGRES_PASSWORD: postgres\n      POSTGRES_DB: online_judge\n    ports:\n      - \"5432:5432\"\n    volumes:\n      - postgres_data:/var/lib/postgresql/data\n    healthcheck:\n      test: [\"CMD-SHELL\", \"pg_isready -U postgres -d online_judge\"]\n      interval: 10s\n      timeout: 5s\n      retries: 5\n      start_period: 30s\n\n  redis:\n    image: redis:7-alpine\n    container_name: online-judge-redis\n    restart: unless-stopped\n    ports:\n      - \"6379:6379\"\n    volumes:\n      - redis_data:/data\n    healthcheck:\n      test: [\"CMD\", \"redis-cli\", \"ping\"]\n      interval: 10s\n      timeout: 5s\n      retries: 5\n      start_period: 10s\n\n  api:\n    build:\n      context: ./backend\n      dockerfile: api/Dockerfile\n    container_name: online-judge-api\n    restart: unless-stopped\n    ports:\n      - \"3000:3000\"\n    environment:\n      APP_ENV: production\n      DATABASE_URL: postgresql://postgres:postgres@postgres:5432/online_judge\n      REDIS_URL: redis://redis:6379\n      JWT_SECRET: ${JWT_SECRET:-default_jwt_secret_change_me}\n      WORKER_SECRET: ${WORKER_SECRET:-default_worker_secret_change_me}\n      API_BIND_ADDRESS: 0.0.0.0:3000\n      FEATURE_GATEWAY_URL: http://feature-gateway:3001\n      RUST_LOG: api=debug,tower_http=debug,axum=trace\n    depends_on:\n      postgres:\n        condition: service_healthy\n      redis:\n        condition: service_healthy\n      feature-gateway:\n        condition: service_healthy\n    healthcheck:\n      test: [\"CMD\", \"curl\", \"-f\", \"http://localhost:3000/health/ready\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 40s\n\n  frontend:\n    build:\n      context: ./frontend\n      dockerfile: Dockerfile\n    container_name: online-judge-frontend\n    restart: unless-stopped\n    ports:\n      - \"5173:80\"\n    environment:\n      VITE_API_BASE_URL: http://localhost:3000\n      VITE_WS_BASE_URL: ws://localhost:3000\n    depends_on:\n      api:\n        condition: service_healthy\n\n  feature-gateway:\n    build:\n      context: ./backend\n      dockerfile: feature-gateway/Dockerfile\n    container_name: online-judge-feature-gateway\n    restart: unless-stopped\n    ports:\n      - \"3001:3001\"\n    environment:\n      APP_ENV: production\n      DATABASE_URL: postgresql://postgres:postgres@postgres:5432/online_judge\n      FEATURE_GATEWAY_ENABLED: \"true\"\n      GATEWAY_BIND_ADDRESS: 0.0.0.0:3001\n      WORKER_SECRET: ${WORKER_SECRET:-default_worker_secret_change_me}\n      RUST_LOG: feature_gateway=debug\n    depends_on:\n      postgres:\n        condition: service_healthy\n    healthcheck:\n      test:\n        [\n          \"CMD-SHELL\",\n          \"curl -f -H \\\"Authorization: Bearer $$WORKER_SECRET\\\" http://localhost:3001/health || exit 1\",\n        ]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 20s\n\n  judge-worker:\n    build:\n      context: ./backend\n      dockerfile: judge-worker/Dockerfile\n    container_name: online-judge-judge-worker\n    restart: unless-stopped\n    environment:\n      APP_ENV: production\n      DATABASE_URL: postgresql://postgres:postgres@postgres:5432/online_judge\n      REDIS_URL: redis://redis:6379\n      API_URL: http://api:3000\n      WORKER_SECRET: ${WORKER_SECRET:-default_worker_secret_change_me}\n    depends_on:\n      postgres:\n        condition: service_healthy\n      redis:\n        condition: service_healthy\n      api:\n        condition: service_healthy\n    volumes:\n      - /var/run/docker.sock:/var/run/docker.sock\n    cap_add:\n      - SYS_PTRACE\n      - SYS_ADMIN\n    security_opt:\n      - no-new-privileges:true\n    healthcheck:\n      test:\n        [\n          \"CMD-SHELL\",\n          \"pgrep -f judge-worker >/dev/null && python3 -c \\\"import socket; s=socket.create_connection(('redis', 6379), 3); s.sendall(b'PING\\\\r\\\\n'); assert b'PONG' in s.recv(16); s.close()\\\" && curl -f http://api:3000/health/ready\",\n        ]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 10s\n\n  llm-worker:\n    build:\n      context: ./backend\n      dockerfile: llm-worker/Dockerfile\n    container_name: online-judge-llm-worker\n    restart: unless-stopped\n    environment:\n      APP_ENV: production\n      DATABASE_URL: postgresql://postgres:postgres@postgres:5432/online_judge\n      REDIS_URL: redis://redis:6379\n      LLM_API_URL: ${LLM_API_URL:-http://host.docker.internal:11434}\n      LLM_API_KEY: ${LLM_API_KEY:-}\n      LLM_MODEL: ${LLM_MODEL:-deepseek-coder}\n      LLM_TIMEOUT_SECS: \"60\"\n      LLM_MAX_RETRIES: \"3\"\n      RUST_LOG: llm_worker=debug\n    depends_on:\n      postgres:\n        condition: service_healthy\n      redis:\n        condition: service_healthy\n    healthcheck:\n      test:\n        [\n          \"CMD-SHELL\",\n          \"pgrep -f llm-worker >/dev/null || exit 1\",\n        ]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n      start_period: 15s\n\nvolumes:\n  postgres_data:\n    driver: local\n  redis_data:\n    driver: local\n"