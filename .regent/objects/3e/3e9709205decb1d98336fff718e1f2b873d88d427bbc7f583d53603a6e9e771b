/* ─── Base Layer ───────────────────────────────────────────────────────── */

@layer base {
  * {
    @apply border-border outline-ring/50;
    box-sizing: border-box;
  }

  body {
    @apply bg-background text-foreground;
    font-family: var(--font-sans);
    font-feature-settings: "cv01", "ss03";
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  html {
    scroll-behavior: smooth;
  }
}

/* ─── Custom Scrollbar (Linear style) ──────────────────────────────────── */

::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.25);
}

:not(.dark) ::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.15);
}

:not(.dark) ::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 0, 0, 0.25);
}

/* ─── Animations ───────────────────────────────────────────────────────── */

@keyframes spin {
  to { transform: rotate(360deg); }
}

.animate-spin {
  animation: spin 1s linear infinite;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes slideInLeft {
  from { transform: translateX(-100%); }
  to { transform: translateX(0); }
}

@keyframes slideInRight {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes pulseGlow {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

.fade-in        { animation: fadeIn 0.3s ease-out both; }
.fade-in-up     { animation: fadeInUp 0.4s ease-out both; }
.fade-in-down   { animation: fadeInDown 0.4s ease-out both; }
.scale-in       { animation: scaleIn 0.3s ease-out both; }
.slide-in       { animation: slideInLeft 0.3s ease-out; }
.slide-in-right { animation: slideInRight 0.3s ease-out; }

/* Staggered children — apply to parent */
.stagger-children > * {
  animation: fadeInUp 0.4s ease-out both;
}
.stagger-children > *:nth-child(1)  { animation-delay: 0ms; }
.stagger-children > *:nth-child(2)  { animation-delay: 50ms; }
.stagger-children > *:nth-child(3)  { animation-delay: 100ms; }
.stagger-children > *:nth-child(4)  { animation-delay: 150ms; }
.stagger-children > *:nth-child(5)  { animation-delay: 200ms; }
.stagger-children > *:nth-child(6)  { animation-delay: 250ms; }
.stagger-children > *:nth-child(7)  { animation-delay: 300ms; }
.stagger-children > *:nth-child(8)  { animation-delay: 350ms; }
.stagger-children > *:nth-child(9)  { animation-delay: 400ms; }
.stagger-children > *:nth-child(10) { animation-delay: 450ms; }

/* Shimmer skeleton loader */
.shimmer {
  background: linear-gradient(
    90deg,
    var(--muted) 25%,
    var(--muted-foreground) 50%,
    var(--muted) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

/* Pulse glow — for live indicators */
.pulse-glow {
  animation: pulseGlow 2s ease-in-out infinite;
}

/* ─── Shadow Scale ─────────────────────────────────────────────────────── */

/*
  Usage: shadow-xs  → subtle border-like (cards)
         shadow-sm  → light lift (hover states)
         shadow-md  → medium elevation (dropdowns)
         shadow-lg  → prominent (modals)
         shadow-xl  → dramatic (hero elements)
         shadow-glow-{color} → colored glow (CTAs, live badges)
*/

.shadow-glow-primary {
  box-shadow: 0 0 20px -4px oklch(0.612 0.184 267 / 30%);
}

.shadow-glow-green {
  box-shadow: 0 0 20px -4px oklch(0.737 0.169 155 / 30%);
}

.shadow-glow-amber {
  box-shadow: 0 0 20px -4px oklch(0.762 0.178 72 / 30%);
}

.shadow-glow-rose {
  box-shadow: 0 0 20px -4px oklch(0.623 0.239 25 / 30%);
}

.dark .shadow-glow-primary {
  box-shadow: 0 0 24px -4px oklch(0.612 0.184 267 / 25%);
}

.dark .shadow-glow-green {
  box-shadow: 0 0 24px -4px oklch(0.737 0.169 155 / 25%);
}

.dark .shadow-glow-amber {
  box-shadow: 0 0 24px -4px oklch(0.762 0.178 72 / 25%);
}

.dark .shadow-glow-rose {
  box-shadow: 0 0 24px -4px oklch(0.623 0.239 25 / 25%);
}

/* ─── Surface & Material Utilities ─────────────────────────────────────── */

/* Glass/frosted panel */
.glass {
  background: oklch(1 0 0 / 60%);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid oklch(1 0 0 / 18%);
}

.dark .glass {
  background: oklch(0.12 0.005 260 / 60%);
  border: 1px solid oklch(1 0 0 / 10%);
}

/* Subtle gradient overlay for hero sections */
.hero-gradient {
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%, oklch(0.612 0.184 267 / 8%), transparent),
    radial-gradient(ellipse 40% 50% at 80% 100%, oklch(0.737 0.169 155 / 6%), transparent);
}

.dark .hero-gradient {
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%, oklch(0.612 0.184 267 / 12%), transparent),
    radial-gradient(ellipse 40% 50% at 80% 100%, oklch(0.737 0.169 155 / 8%), transparent);
}

/* Inset surface — sunken panels, wells */
.surface-inset {
  background: var(--muted);
  border: 1px solid var(--border);
  border-radius: calc(var(--radius) * 1.4);
}

/* Raised surface — cards that sit above the background */
.surface-raised {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: calc(var(--radius) * 1.4);
  box-shadow: 0 1px 2px oklch(0 0 0 / 4%);
}

.dark .surface-raised {
  box-shadow: 0 1px 3px oklch(0 0 0 / 20%), 0 1px 2px oklch(0 0 0 / 12%);
}

/* ─── Transition Utilities ─────────────────────────────────────────────── */

/* Card hover lift — apply to any card */
.hover-lift {
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}
.hover-lift:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px -5px oklch(0 0 0 / 10%), 0 4px 10px -5px oklch(0 0 0 / 6%);
}

.dark .hover-lift:hover {
  box-shadow: 0 8px 25px -5px oklch(0 0 0 / 30%), 0 4px 10px -5px oklch(0 0 0 / 20%);
}

/* Subtle border highlight on hover */
.hover-border {
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.hover-border:hover {
  border-color: oklch(0.612 0.184 267 / 40%);
  box-shadow: 0 0 0 1px oklch(0.612 0.184 267 / 10%);
}

/* Interactive row highlight */
.hover-row {
  transition: background-color 0.15s ease;
}
.hover-row:hover {
  background-color: oklch(0.965 0.003 260);
}

.dark .hover-row:hover {
  background-color: oklch(0.16 0.008 260);
}
