@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@400;500;600&display=swap');
@import "tw-animate-css";
@import "shadcn/tailwind.css";

@custom-variant dark (&:is(.dark *));

@tailwind base;
@tailwind components;
@tailwind utilities;

/* ─── shadcn/ui Theme Inline ──────────────────────────────────────────── */

@theme inline {
  --font-heading: var(--font-sans);
  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-mono: 'Fira Code', 'SF Mono', Monaco, 'Courier New', monospace;

  /* shadcn color mappings */
  --color-sidebar-ring: var(--sidebar-ring);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar: var(--sidebar);
  --color-chart-5: var(--chart-5);
  --color-chart-4: var(--chart-4);
  --color-chart-3: var(--chart-3);
  --color-chart-2: var(--chart-2);
  --color-chart-1: var(--chart-1);
  --color-ring: var(--ring);
  --color-input: var(--input);
  --color-border: var(--border);
  --color-destructive: var(--destructive);
  --color-accent-foreground: var(--accent-foreground);
  --color-accent: var(--accent);
  --color-muted-foreground: var(--muted-foreground);
  --color-muted: var(--muted);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-secondary: var(--secondary);
  --color-primary-foreground: var(--primary-foreground);
  --color-primary: var(--primary);
  --color-popover-foreground: var(--popover-foreground);
  --color-popover: var(--popover);
  --color-card-foreground: var(--card-foreground);
  --color-card: var(--card);
  --color-foreground: var(--foreground);
  --color-background: var(--background);

  /* OJ status colors */
  --color-status-accepted: var(--status-accepted);
  --color-status-wrong: var(--status-wrong);
  --color-status-pending: var(--status-pending);
  --color-status-tle: var(--status-tle);
  --color-status-re: var(--status-re);

  /* OJ difficulty colors */
  --color-difficulty-easy: var(--difficulty-easy);
  --color-difficulty-medium: var(--difficulty-medium);
  --color-difficulty-hard: var(--difficulty-hard);

  /* Semantic accent colors — replaces hardcoded hex in pages */
  --color-accent-green: var(--accent-green);
  --color-accent-blue: var(--accent-blue);
  --color-accent-amber: var(--accent-amber);
  --color-accent-rose: var(--accent-rose);
  --color-accent-purple: var(--accent-purple);
  --color-accent-orange: var(--accent-orange);

  /* Radius scale */
  --radius-sm: calc(var(--radius) * 0.6);
  --radius-md: calc(var(--radius) * 0.8);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) * 1.4);
  --radius-2xl: calc(var(--radius) * 1.8);
  --radius-3xl: calc(var(--radius) * 2.2);
  --radius-4xl: calc(var(--radius) * 2.6);
}

/* ─── Light Theme ──────────────────────────────────────────────────────── */

:root {
  /* Base — sRGB fallbacks for oklch-incompatible browsers */
  --background: #f7f7f8;
  --foreground: #212128;
  --card: #ffffff;
  --card-foreground: #212128;
  --popover: #ffffff;
  --popover-foreground: #212128;

  /* Primary — Linear brand indigo #5e6ad2 */
  --primary: #5e6ad2;
  --primary-foreground: #f7f7f8;

  --secondary: #f1f1f3;
  --secondary-foreground: #303038;

  --muted: #f1f1f3;
  --muted-foreground: #7f7f8c;

  --accent: #f1f1f3;
  --accent-foreground: #303038;

  --destructive: #e5393d;

  --border: #e1e1e5;
  --input: #e1e1e5;
  --ring: #5e6ad2;

  --chart-1: #5e6ad2;
  --chart-2: #3ecf8e;
  --chart-3: #e87040;
  --chart-4: #5b7fd4;
  --chart-5: #404050;

  --radius: 0.375rem;

  --sidebar: #f5f5f8;
  --sidebar-foreground: #212128;
  --sidebar-primary: #5e6ad2;
  --sidebar-primary-foreground: #f7f7f8;
  --sidebar-accent: #eeeef2;
  --sidebar-accent-foreground: #303038;
  --sidebar-border: #e1e1e5;
  --sidebar-ring: #5e6ad2;

  /* OJ Status colors */
  --status-accepted: #3ecf8e;    /* Supabase green */
  --status-wrong: #cf2d56;       /* Cursor red */
  --status-pending: #0a72ef;     /* Vercel blue */
  --status-tle: #ffb287;         /* Sentry orange */
  --status-re: #fa7faa;          /* Sentry pink */

  /* OJ Difficulty colors */
  --difficulty-easy: #10b981;    /* Linear green */
  --difficulty-medium: #F7A501;  /* PostHog amber */
  --difficulty-hard: #ff5b4f;    /* Vercel red */

  /* Semantic accent palette — used via bg-accent-green, text-accent-blue etc. */
  --accent-green: #3ecf8e;
  --accent-blue: #3b82f6;
  --accent-amber: #f59e0b;
  --accent-rose: #ef4444;
  --accent-purple: #8b5cf6;
  --accent-orange: #f97316;
}

