       .route_layer(axum::middleware::from_fn(track_metrics))
       // Request ID wraps everything including metrics
       .route_layer(axum::middleware::from_fn(request_id_middleware))
       .layer(GovernorLayer { ... })
       .layer(cors)
       .with_state(state)
