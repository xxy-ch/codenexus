#### Step 1.2: 修复 `ContestList.tsx` 纯函数问题
**File**: `frontend/src/pages/user/ContestList.tsx`

**当前代码**:
```typescript
const getCountdown = (startTime: string) => {
  const diff = new Date(startTime).getTime() - Date.now() // ❌ Impure
  // ...
}

const getRemainingTime = (endTime: string) => {
  const diff = new Date(endTime).getTime() - Date.now() // ❌ Impure
  // ...
}
```

**问题**: 全局定时器会导致整个组件每秒重新渲染，影响性能

**优化修复方案**:
```typescript
// 创建独立的倒计时hook
const useCountdown = (endTime: string, intervalMs: number = 1000) => {
  const [timeLeft, setTimeLeft] = useState(0)

  useEffect(() => {
    const update = () => {
      const diff = new Date(endTime).getTime() - Date.now()
      setTimeLeft(Math.max(0, diff))
    }

    update()
    const timer = setInterval(update, intervalMs)
    return () => clearInterval(timer)
  }, [endTime, intervalMs])

  return { timeLeft, formattedTime: formatTime(timeLeft) }
}

// 在组件中按需使用
const { timeLeft } = useCountdown(contest.end_time)
```

**验证**: 仅倒计时组件重新渲染，其他组件保持稳定

