```rust
use anyhow::Result;

/// Structural features extracted from source code.
/// Pure computation — no external API calls.
#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub struct StructuralFeatures {
    pub cyclomatic_complexity: f64,
    pub lines_of_code: i32,
    pub token_count: i32,
    pub function_count: i32,
    pub max_nesting_depth: i32,
    pub distinct_operators: i32,
    pub distinct_operands: i32,
    pub halstead_volume: f64,
}

/// Extract structural features from source code.
/// Runs synchronously — designed to be called via `spawn_blocking`.
pub fn extract_features(source_code: &str, language: &str) -> Result<StructuralFeatures> {
    let lines: Vec<&str> = source_code.lines().collect();
    let lines_of_code = lines.iter().filter(|l| !l.trim().is_empty() && !l.trim().starts_with("//")).count() as i32;

    // Function detection by language
    let function_count = count_functions(source_code, language);

    // Nesting depth: track brace/indent levels
    let max_nesting_depth = compute_max_nesting(source_code);

    // Token counting (simplified)
    let tokens: Vec<&str> = source_code.split_whitespace().collect();
    let token_count = tokens.len() as i32;

    // Cyclomatic complexity approximation: count branch keywords
    let branch_keywords = ["if", "else", "for", "while", "case", "&&", "||", "?", "catch"];
    let branch_count: i32 = branch_keywords.iter()
        .map(|kw| source_code.matches(kw).count() as i32)
        .sum();
    let cyclomatic_complexity = (branch_count + 1) as f64;

    // Halstead metrics (simplified operator/operand counting)
    let operators = ["+", "-", "*", "/", "=", "==", "!=", "<", ">", "<=", ">=", "++", "--", "&&", "||", "!", "&", "|", "^", "%"];
    let mut distinct_ops = std::collections::HashSet::new();
    let mut distinct_operands = std::collections::HashSet::new();
    for op in &operators {
        if source_code.contains(op) {
            distinct_ops.insert(*op);
        }
    }
    // Operands: split by operators and whitespace, collect unique non-empty strings
    for token in &tokens {
        let clean = token.chars().filter(|c| c.is_alphanumeric() || *c == '_').collect::<String>();
        if !clean.is_empty() && !operators.iter().any(|op| *op == clean) {
            distinct_operands.insert(clean);
        }
    }
    let distinct_operators = distinct_ops.len() as i32;
    let distinct_operands = distinct_operands.len() as i32;
    let halstead_volume = if distinct_operators + distinct_operands > 0 {
        let n = (distinct_operators + distinct_operands) as f64;
        let n1 = distinct_operators as f64;
        let n2 = distinct_operands as f64;
        n * n.log2()
    } else {
        0.0
    };

    Ok(StructuralFeatures {
        cyclomatic_complexity,
        lines_of_code,
        token_count,
        function_count,
        max_nesting_depth,
        distinct_operators,
        distinct_operands,
        halstead_volume,
    })
}

fn count_functions(source: &str, language: &str) -> i32 {
    let patterns: &[&str] = match language {
        "c" | "cpp" | "c++" => &["void ", "int ", "float ", "double ", "char ", "bool ", "long ", "auto ", "string "],
        "java" => &["public ", "private ", "protected ", "static "],
        "python" | "python3" => &["def "],
        "go" => &["func "],
        "javascript" | "js" => &["function ", "=>", "const ", "let "],
        _ => &["func ", "def ", "function "],
    };
    patterns.iter()
        .filter(|p| source.contains(**p))
        .map(|p| source.matches(*p).count() as i32)
        .sum()
}

fn compute_max_nesting(source: &str) -> i32 {
    let mut depth = 0;
    let mut max_depth = 0;
    for ch in source.chars() {
        match ch {
            '{' | '(' | '[' => {
                depth += 1;
                if depth > max_depth {
                    max_depth = depth;
                }
            }
            '}' | ')' | ']' => {
                depth = depth.saturating_sub(1);
            }
            _ => {}
        }
    }
    max_depth
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_extract_features_simple() {
        let code = "fn main() {\n    println!(\"hello\");\n}\n";
        let features = extract_features(code, "rust").unwrap();
        assert!(features.lines_of_code > 0);
        assert!(features.function_count >= 0);
        assert!(features.max_nesting_depth >= 1);
    }

    #[test]
    fn test_extract_features_empty() {
        let features = extract_features("", "c").unwrap();
        assert_eq!(features.lines_of_code, 0);
    }

    #[test]
