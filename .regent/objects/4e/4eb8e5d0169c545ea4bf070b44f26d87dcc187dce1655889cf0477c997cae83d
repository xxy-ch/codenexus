import api from './api';

export const analysisService = {
  async getSubmissionFeatures(submissionId: number) {
    const { data } = await api.get(`/analysis/submissions/${submissionId}/features`);
    return data;
  },

  async getTeachingCards(problemId: number) {
    const { data } = await api.get(`/analysis/problems/${problemId}/teaching-cards`);
    return data?.cards ?? [];
  },

  async getSolutionClusters(problemId: number) {
    const { data } = await api.get(`/analysis/problems/${problemId}/clusters`);
    return data?.clusters ?? [];
  },

  async getClassCognition(classId: number) {
    const { data } = await api.get(`/analysis/classes/${classId}/cognition`);
    return data;
  },
};
```

