```rust
use axum::{
    extract::{Path, State, Extension},
    Json,
    http::StatusCode,
};
use serde_json::{json, Value};
use sqlx::PgPool;
use uuid::Uuid;

use crate::service::AnalysisService;

/// GET /analysis/submissions/:id/features
/// Returns structural features for a submission.
/// Feature-gated: returns 404 when ai_analysis_enabled is false.
pub async fn get_submission_features(
    State(pool): State<PgPool>,
    Extension(claims): Extension<crate::models::Claims>,
    Path(submission_id): Path<i64>,
) -> Result<Json<Value>, StatusCode> {
    let service = AnalysisService::new(pool);
    let org_id = claims.school_id;
    match service.get_submission_features(submission_id, org_id).await {
        Ok(Some(features)) => Ok(Json(serde_json::to_value(features).unwrap())),
        Ok(None) => Err(StatusCode::NOT_FOUND),
        Err(e) => {
            tracing::error!(error = %e, "Failed to get submission features");
            Err(StatusCode::INTERNAL_SERVER_ERROR)
        }
    }
}

/// GET /analysis/problems/:id/teaching-cards
/// Returns teaching cards for a problem.
pub async fn get_teaching_cards(
    State(pool): State<PgPool>,
    Extension(claims): Extension<crate::models::Claims>,
    Path(problem_id): Path<i64>,
) -> Result<Json<Value>, StatusCode> {
    let service = AnalysisService::new(pool);
    let org_id = claims.school_id;
    match service.get_teaching_cards(problem_id, org_id).await {
        Ok(cards) => Ok(Json(json!({ "cards": cards }))),
        Err(e) => {
            tracing::error!(error = %e, "Failed to get teaching cards");
            Err(StatusCode::INTERNAL_SERVER_ERROR)
        }
    }
}

/// GET /analysis/problems/:id/clusters
/// Returns solution clusters for a problem.
pub async fn get_solution_clusters(
    State(pool): State<PgPool>,
    Extension(claims): Extension<crate::models::Claims>,
    Path(problem_id): Path<i64>,
) -> Result<Json<Value>, StatusCode> {
    let service = AnalysisService::new(pool);
    let org_id = claims.school_id;
    match service.get_solution_clusters(problem_id, org_id).await {
        Ok(clusters) => Ok(Json(json!({ "clusters": clusters }))),
        Err(e) => {
            tracing::error!(error = %e, "Failed to get solution clusters");
            Err(StatusCode::INTERNAL_SERVER_ERROR)
        }
    }
}

/// GET /analysis/classes/:id/cognition
/// Returns the latest class cognition snapshot.
pub async fn get_class_cognition(
    State(pool): State<PgPool>,
    Extension(claims): Extension<crate::models::Claims>,
    Path(class_id): Path<i64>,
) -> Result<Json<Value>, StatusCode> {
    let service = AnalysisService::new(pool);
    let org_id = claims.school_id;
    match service.get_class_snapshot(class_id, org_id).await {
        Ok(Some(snapshot)) => Ok(Json(serde_json::to_value(snapshot).unwrap())),
        Ok(None) => Err(StatusCode::NOT_FOUND),
        Err(e) => {
            tracing::error!(error = %e, "Failed to get class cognition");
            Err(StatusCode::INTERNAL_SERVER_ERROR)
        }
    }
}
```

