/// Configuration for the nightly batch processor.
pub struct BatchConfig {
    /// Whether batch processing is enabled (requires ai_analysis_enabled feature flag)
    pub enabled: bool,
    /// Hour of day to run batch (UTC, 0-23)
    pub run_hour_utc: u32,
    /// Maximum submissions to process per organization per batch run
    pub batch_size: i64,
    /// Whether LLM-based generation is enabled (requires AI_API_KEY)
    pub llm_enabled: bool,
}

impl Default for BatchConfig {
    fn default() -> Self {
        Self {
            enabled: false,
            run_hour_utc: 2,
            batch_size: 1000,
            llm_enabled: false,
        }
    }
}

impl BatchConfig {
    pub fn from_env() -> Self {
        Self {
            enabled: env::var("AI_BATCH_ENABLED").unwrap_or_default() == "true",
            run_hour_utc: env::var("AI_BATCH_HOUR")
                .ok()
                .and_then(|v| v.parse().ok())
                .unwrap_or(2),
            batch_size: env::var("AI_BATCH_SIZE")
                .ok()
                .and_then(|v| v.parse().ok())
                .unwrap_or(1000),
            llm_enabled: env::var("AI_API_KEY").ok().map(|k| !k.is_empty()).unwrap_or(false),
        }
    }
}

/// Run the nightly batch process for all organizations.
/// Processes: feature backfill, reclustering, cluster naming,
/// teaching-card refresh, class snapshots, stale cleanup.
pub async fn run_nightly_batch(pool: PgPool, config: &BatchConfig) -> Result<()> {
    if !config.enabled {
        info!("Nightly batch disabled — skipping");
        return Ok(());
    }

    let service = AnalysisService::new(pool.clone());
    let now = Utc::now();
    let today = now.date_naive();

    info!(date = %today, "Starting nightly analysis batch");

    // Step 1: Backfill features for pending jobs
    match backfill_pending_features(&service, &pool, config.batch_size).await {
        Ok(count) => info!(count, "Feature backfill complete"),
        Err(e) => error!(error = %e, "Feature backfill failed"),
    }

    // Step 2: Recluster solutions per problem per organization
    match recluster_solutions(&service, &pool, config.batch_size).await {
        Ok(count) => info!(count, "Reclustering complete"),
        Err(e) => error!(error = %e, "Reclustering failed"),
    }

    // Step 3: Generate teaching cards (if LLM enabled)
    if config.llm_enabled {
        match generate_teaching_cards(&service, &pool).await {
            Ok(count) => info!(count, "Teaching card generation complete"),
            Err(e) => error!(error = %e, "Teaching card generation failed"),
        }
    }

    // Step 4: Build class cognition snapshots
    match build_class_snapshots(&service, &pool, today).await {
        Ok(count) => info!(count, "Class snapshot build complete"),
        Err(e) => error!(error = %e, "Class snapshot build failed"),
    }

    // Step 5: Invalidate stale artifacts
    match invalidate_stale(&pool).await {
        Ok(count) => info!(count, "Stale artifact cleanup complete"),
        Err(e) => error!(error = %e, "Stale cleanup failed"),
    }

    info!("Nightly analysis batch complete");
    Ok(())
}

async fn backfill_pending_features(service: &AnalysisService, pool: &PgPool, batch_size: i64) -> Result<u64> {
    // Find pending jobs and extract features
    let pending = sqlx::query_as::<_, AnalysisJob>(
        "SELECT * FROM analysis_jobs WHERE status = 'pending' ORDER BY created_at ASC LIMIT $1"
    )
    .bind(batch_size)
    .fetch_all(pool)
    .await?;

    let mut processed = 0u64;
    for job in &pending {
        if let Err(e) = process_job(service, pool, job).await {
            warn!(job_id = job.id, error = %e, "Failed to process analysis job");
        } else {
            processed += 1;
        }
    }
    Ok(processed)
}

async fn process_job(service: &AnalysisService, pool: &PgPool, job: &AnalysisJob) -> Result<()> {
    service.mark_processing(job.id).await?;

    // Fetch submission source code
    let source: Option<(String, String)> = sqlx::query_as(
        "SELECT s.source_code, s.language FROM submissions s WHERE s.id = $1"
    )
    .bind(job.submission_id)
    .fetch_optional(pool)
    .await?;

    if let Some((source_code, language)) = source {
        let features = tokio::task::spawn_blocking(move || {
            extractor::extract_features(&source_code, &language)
        })
        .await??;

        service.store_features(job.submission_id, job.organization_id, &features).await?;
    }

    service.mark_completed(job.id).await?;
    Ok(())
}

async fn recluster_solutions(service: &AnalysisService, pool: &PgPool, _batch_size: i64) -> Result<u64> {
    // Placeholder: Real implementation would use embedding-based clustering
    // For v1, we do a simplified grouping by cyclomatic_complexity buckets
    let orgs: Vec<(i64,)> = sqlx::query_as("SELECT DISTINCT organization_id FROM analysis_submission_features")
        .fetch_all(pool)
        .await?;

    let mut count = 0u64;
    for (org_id,) in &orgs {
        let problems: Vec<(i64,)> = sqlx::query_as(
            "SELECT DISTINCT aj.problem_id FROM analysis_jobs aj
             JOIN analysis_submission_features af ON af.submission_id = aj.submission_id
             WHERE aj.organization_id = $1 AND aj.status = 'completed'"
        )
        .bind(org_id)
        .fetch_all(pool)
        .await?;

        for (problem_id,) in problems {
            // Delete old clusters for this problem+org
            sqlx::query("DELETE FROM analysis_solution_clusters WHERE problem_id = $1 AND organization_id = $2")
                .bind(problem_id)
                .bind(org_id)
                .execute(pool)
                .await?;

            // Group submissions by complexity bucket
            let clusters = sqlx::query_as::<_, (String, i32)>(
                "SELECT CASE
                    WHEN cyclomatic_complexity < 3 THEN 'simple'
                    WHEN cyclomatic_complexity < 8 THEN 'moderate'
                    ELSE 'complex'
                END as bucket, COUNT(*) as cnt
                FROM analysis_submission_features af
                JOIN analysis_jobs aj ON aj.submission_id = af.submission_id
                WHERE aj.problem_id = $1 AND aj.organization_id = $2
                GROUP BY bucket"
            )
            .bind(problem_id)
            .bind(org_id)
            .fetch_all(pool)
            .await?;

            for (bucket_name, member_count) in clusters {
                let cluster = sqlx::query_as::<_, AnalysisSolutionCluster>(
                    "INSERT INTO analysis_solution_clusters (problem_id, organization_id, cluster_name, member_count)
                     VALUES ($1, $2, $3, $4) RETURNING *"
                )
                .bind(problem_id)
                .bind(org_id)
                .bind(&bucket_name)
                .bind(member_count)
                .fetch_one(pool)
                .await?;

                // Assign members
                sqlx::query(
                    "INSERT INTO analysis_cluster_members (cluster_id, submission_id, organization_id)
                     SELECT $1, aj.submission_id, $2
                     FROM analysis_jobs aj
                     JOIN analysis_submission_features af ON af.submission_id = aj.submission_id
                     WHERE aj.problem_id = $3 AND aj.organization_id = $2
                       AND CASE
                         WHEN $4 = 'simple' THEN af.cyclomatic_complexity < 3
                         WHEN $4 = 'moderate' THEN af.cyclomatic_complexity >= 3 AND af.cyclomatic_complexity < 8
                         WHEN $4 = 'complex' THEN af.cyclomatic_complexity >= 8
                         ELSE false
                       END"
                )
                .bind(cluster.id)
                .bind(org_id)
                .bind(problem_id)
                .bind(&bucket_name)
                .execute(pool)
                .await?;

                count += 1;
            }
        }
    }
    Ok(count)
}

