async fn build_class_snapshots(service: &AnalysisService, pool: &PgPool, date: NaiveDate) -> Result<u64> {
    let classes: Vec<(i64, i64)> = sqlx::query_as(
        "SELECT DISTINCT ce.class_id, c.organization_id
         FROM class_enrollments ce
         JOIN classes c ON c.id = ce.class_id
         WHERE c.is_active = true"
    )
    .fetch_all(pool)
    .await?;

    let mut count = 0u64;
    for (class_id, org_id) in &classes {
        // Compute avg complexity for the class
        let stats = sqlx::query_as::<_, (i32, Option<f64>)>(
            "SELECT COUNT(DISTINCT af.submission_id), AVG(af.cyclomatic_complexity)
             FROM analysis_submission_features af
             JOIN submissions s ON s.id = af.submission_id
             JOIN class_enrollments ce ON ce.user_id = s.user_id
             WHERE ce.class_id = $1 AND af.organization_id = $2"
        )
        .bind(class_id)
        .bind(org_id)
        .fetch_one(pool)
        .await?;

        let (student_count, avg_complexity) = stats;
        let cognition_profile = serde_json::json!({
            "student_count": student_count,
            "avg_complexity": avg_complexity,
            "snapshot_type": "simplified_v1"
        });

        sqlx::query(
            "INSERT INTO analysis_class_snapshots (class_id, organization_id, snapshot_date, cognition_profile, student_count, avg_complexity)
             VALUES ($1, $2, $3, $4, $5, $6)
             ON CONFLICT (class_id, snapshot_date) DO UPDATE SET
                cognition_profile = $4, student_count = $5, avg_complexity = $6"
        )
        .bind(class_id)
        .bind(org_id)
        .bind(date)
        .bind(serde_json::to_value(&cognition_profile)?)
        .bind(student_count)
        .bind(avg_complexity)
        .execute(pool)
        .await?;

        count += 1;
    }
    Ok(count)
}

async fn invalidate_stale(pool: &PgPool) -> Result<u64> {
    // Mark analysis_jobs older than 30 days as expired
    let result = sqlx::query(
        "UPDATE analysis_jobs SET status = 'expired', updated_at = NOW()
         WHERE status IN ('pending', 'processing') AND created_at < NOW() - INTERVAL '30 days'"
    )
    .execute(pool)
    .await?;
    Ok(result.rows_affected())
}
