import { Outlet, Link, useLocation } from 'react-router-dom'
import {
  BookOpen,
  Code2,
  Database,
  Edit,
  FileSearch,
  LayoutDashboard,
  School,
  SlidersHorizontal,
  Users,
  ArrowLeft,
  Cog,
} from 'lucide-react'
import { cn } from '@/lib/utils'
import { useFeatureEnabled } from '@/hooks/useFeatureGate'
import type { LucideIcon } from 'lucide-react'

interface AdminNavItem {
  name: string
  href: string
  icon: LucideIcon
}

export function AdminLayout() {
  const location = useLocation()
  const { enabled: plagiarismEnabled } = useFeatureEnabled('plagiarism')

  const navigation: AdminNavItem[] = [
    { name: '仪表板', href: '/admin', icon: LayoutDashboard },
    { name: '用户管理', href: '/admin/users', icon: Users },
    { name: '年级管理', href: '/admin/grades', icon: School },
    { name: '题目管理', href: '/admin/problems', icon: BookOpen },
    { name: '判题设置', href: '/admin/judge-settings', icon: SlidersHorizontal },
    { name: '判题队列', href: '/admin/judge-queue', icon: Database },
    { name: '题面配置', href: '/admin/problem-content', icon: Edit },
    { name: '功能开关', href: '/admin/features', icon: Cog },
    ...(plagiarismEnabled
      ? [
          { name: '相似度配置', href: '/admin/similarity-scan', icon: SlidersHorizontal },
          { name: '抄袭报告', href: '/admin/plagiarism-reports', icon: FileSearch },
        ]
      : []),
  ]

  return (
    <div className="bg-background text-foreground antialiased h-screen flex flex-col overflow-hidden">
      {/* Admin Header */}
      <header className="h-12 bg-card border-b border-border flex items-center justify-between px-4 lg:px-6 z-10 shrink-0">
        <div className="flex items-center gap-6 min-w-0">
          <Link to="/" className="flex items-center gap-2 shrink-0">
            <Code2 className="h-5 w-5 text-primary" />
            <span className="font-semibold text-sm">CodeNexus</span>
            <span className="text-[11px] font-medium bg-primary/10 text-primary px-1.5 py-0.5 rounded">Admin</span>
          </Link>
          <nav className="hidden md:flex items-center gap-1 overflow-x-auto min-w-0">
            {navigation.map((item) => {
              const isActive = location.pathname === item.href
              const Icon = item.icon
              return (
                <Link
                  key={item.href}
                  to={item.href}
                  className={cn(
                    'flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-medium transition-colors whitespace-nowrap shrink-0',
                    isActive
                      ? 'bg-primary/10 text-primary'
                      : 'text-muted-foreground hover:bg-muted hover:text-foreground'
                  )}
                >
                  <Icon className="h-[16px] w-[16px]" />
                  {item.name}
                </Link>
              )
            })}
          </nav>
        </div>
        <Link
          to="/dashboard"
          className="flex items-center gap-1.5 text-[13px] text-muted-foreground hover:text-foreground transition-colors shrink-0"
        >
          <ArrowLeft className="h-3.5 w-3.5" />
          <span className="hidden sm:inline">返回主界面</span>
        </Link>
      </header>

      {/* Content */}
      <main className="flex-1 overflow-y-auto">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <Outlet />
        </div>
      </main>
    </div>
  )
}
