{"command":"node --input-type=module <<'EOF'\nimport { chromium } from 'playwright';\nconst baseURL = 'http://127.0.0.1:5175';\nconst browser = await chromium.launch({ headless: true });\nconst page = await browser.newPage();\nconst events = [];\npage.on('request', req => {\n  if (req.method() === 'POST' && req.url().includes('/submissions')) {\n    events.push({ type: 'request', url: req.url(), postData: req.postData() });\n  }\n});\npage.on('response', async res => {\n  if (res.request().method() === 'POST' && res.url().includes('/submissions')) {\n    let body = '';\n    try { body = await res.text(); } catch {}\n    events.push({ type: 'response', url: res.url(), status: res.status(), body: body.slice(0, 500) });\n  }\n});\npage.on('console', msg => events.push({ type: 'console', level: msg.type(), text: msg.text() }));\nawait page.goto(`${baseURL}/login`);\nawait page.getByLabel(/用户名/).fill('2001');\nawait page.getByLabel(/密码/).fill('admin123');\nawait page.getByRole('button', { name: /^登录$/ }).click();\nawait page.waitForURL(/dashboard/, { timeout: 10000 });\nawait page.goto(`${baseURL}/problems/1/solve`);\nawait page.locator('.monaco-editor').waitFor({ timeout: 15000 });\nawait page.locator('.monaco-editor').click();\nawait page.keyboard.insertText(\"import sys\\ns=sys.stdin.read()\\nprint('[0,1]' if '2,7' in s else '[1,2]')\\n\");\nawait page.getByRole('button', { name: 'Judge' }).click();\nawait page.waitForResponse(res => res.url().includes('/submissions') && res.request().method() === 'POST', { timeout: 15000 });\nawait page.waitForURL(/\\/submissions\\/\\d+/, { timeout: 15000 }).catch(() => {});\nconsole.log(JSON.stringify({ url: page.url(), events }, null, 2));\nawait browser.close();\nEOF"}