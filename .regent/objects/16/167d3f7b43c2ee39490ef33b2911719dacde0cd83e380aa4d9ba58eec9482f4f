{"command":"node --input-type=module <<'EOF'\nimport { chromium } from 'playwright';\nconst baseURL = 'http://127.0.0.1:5175';\nconst browser = await chromium.launch({ headless: true });\nconst page = await browser.newPage();\nconst captured = [];\npage.on('request', req => {\n  if (req.method() === 'POST' && req.url().includes('/submissions')) captured.push({ kind: 'request', postData: req.postData() });\n});\npage.on('response', async res => {\n  if (res.request().method() === 'POST' && res.url().includes('/submissions')) captured.push({ kind: 'response', status: res.status(), body: (await res.text()).slice(0, 300) });\n});\nawait page.goto(`${baseURL}/login`);\nawait page.getByLabel(/用户名/).fill('2001');\nawait page.getByLabel(/密码/).fill('admin123');\nawait page.getByRole('button', { name: /^登录$/ }).click();\nawait page.waitForURL(/dashboard/);\nawait page.goto(`${baseURL}/problems/1/solve`);\nawait page.locator('.monaco-editor').waitFor({ timeout: 15000 });\nawait page.locator('.monaco-editor').click();\nawait page.keyboard.insertText(\"import sys\\ns=sys.stdin.read()\\nprint('[0,1]' if '2,7' in s else '[1,2]')\\n\");\nawait page.getByRole('button', { name: 'Judge' }).click();\nawait page.waitForURL(/\\/submissions\\/(\\d+)/, { timeout: 15000 });\nconst id = page.url().match(/submissions\\/(\\d+)/)?.[1];\nawait browser.close();\nconsole.log(JSON.stringify({ id, captured }, null, 2));\nEOF"}