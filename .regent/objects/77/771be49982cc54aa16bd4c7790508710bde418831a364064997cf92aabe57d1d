{
  "title": "Backend Functional Audit, Production Deployment Testing, AI Features, and Frontend Verification",
  "version": "1.0.0",
  "stories": [
    {
      "id": "US-001",
      "title": "Map and document all backend functional lines",
      "description": "Systematically audit every backend domain crate, documenting routes, services, models, and inter-dependencies.",
      "priority": 1,
      "passes": true,
      "acceptanceCriteria": [
        "Every domain crate (19 crates) is documented with its routes, service methods, and key models",
        "Inter-crate dependency graph is identified",
        "All API endpoints are listed with HTTP methods and auth requirements"
      ]
    },
    {
      "id": "US-002",
      "title": "Build Docker images for production deployment",
      "description": "Build all Docker images for production testing. Ensure Dockerfiles are correct and images build successfully.",
      "priority": 2,
      "passes": true,
      "acceptanceCriteria": [
        "docker-compose build succeeds for all services without errors",
        "All Dockerfiles have correct base images, build steps, and runtime configurations",
        "Cargo.lock is up to date"
      ]
    },
    {
      "id": "US-003",
      "title": "Deploy services with docker-compose and verify startup",
      "description": "Start all services via docker-compose. Verify PostgreSQL, Redis, API, frontend, feature-gateway, and workers start correctly.",
      "priority": 3,
      "passes": true,
      "acceptanceCriteria": [
        "docker-compose up starts all services without crashes",
        "API server responds on port 3000",
        "Frontend serves with valid HTML",
        "Database migrations complete successfully",
        "Redis connection is established for all workers"
      ]
    },
    {
      "id": "US-004",
      "title": "Browser-based testing of core API flows with real data",
      "description": "Test all major functional lines end-to-end using browser: auth, problems, submissions, contests, classes, community, search. All data must be real.",
      "priority": 4,
      "passes": true,
      "acceptanceCriteria": [
        "Auth flow: register, login, JWT token, refresh, logout",
        "Problem flow: admin creates problem with test cases, student views and submits",
        "Submission flow: code submitted, judged, result returned",
        "Contest flow: create, register, participate",
        "Class flow: create, enroll, assign",
        "Community flow: blog article, comment, like",
        "Multi-tenancy: data isolated by organization_id"
      ]
    },
    {
      "id": "US-005",
      "title": "Code formatting and standards audit",
      "description": "Run cargo fmt and clippy on all backend crates. Fix all warnings and format issues.",
      "priority": 5,
      "passes": true,
      "acceptanceCriteria": [
        "cargo fmt --check passes with zero differences",
        "cargo clippy passes with zero warnings",
        "All backend crates compile without warnings"
      ]
    },
    {
      "id": "US-006",
      "title": "Complete LLM worker AI functionality",
      "description": "Ensure llm-worker is fully functional: connects to LLM API, processes analysis jobs, generates teaching cards, writes results to DB.",
      "priority": 6,
      "passes": true,
      "acceptanceCriteria": [
        "llm-worker connects to OpenAI-compatible API with AI_API_KEY",
        "llm-worker consumes analysis jobs from analysis_events Redis stream",
        "Teaching cards are generated and stored in analysis_teaching_cards table",
        "Analysis jobs are updated with status, token counts, and latency",
        "Error handling: failed jobs are retried or marked as failed",
        "domain-analysis routes can trigger LLM analysis and return teaching cards"
      ]
    },
    {
      "id": "US-007",
      "title": "Update all configuration and environment files",
      "description": "Ensure docker-compose.yml, Dockerfiles, .env files are consistent with current codebase.",
      "priority": 7,
      "passes": true,
      "acceptanceCriteria": [
        "docker-compose.yml references correct services, ports, and env vars",
        "All Dockerfiles use correct build steps",
        "Environment variables documented and configured",
        "No stale references"
      ]
    },
    {
      "id": "US-008",
      "title": "Verify frontend builds and connects to backend",
      "description": "Build frontend for production, verify connection to API, all pages render correctly.",
      "priority": 8,
      "passes": true,
      "acceptanceCriteria": [
        "npm run build succeeds without errors",
        "Frontend connects to API and loads data",
        "All routes resolve to valid page components",
        "No console errors from API mismatches",
        "WebSocket connections establish"
      ]
    }
