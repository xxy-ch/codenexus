{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/features/community/services/**/*.ts",
    "src/features/community/types/**/*.ts",
    "src/features/admin/services/**/*.ts",
    "src/features/admin/types/**/*.ts",
    "src/features/community/components/messages/**/*.tsx",
    "src/features/community/pages/DirectMessages.tsx",
    "src/features/admin/pages/SimilarityScanConfig.tsx",
    "src/features/admin/pages/PlagiarismReportList.tsx",
    "src/features/admin/pages/PlagiarismReportDetail.tsx",
    "src/features/admin/pages/JudgeSettings.tsx",
    "src/features/admin/pages/ProblemContentConfig.tsx"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**"
  ]
}
