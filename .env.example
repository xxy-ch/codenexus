# Copy to .env for local Docker Compose runs. Values below are examples only.
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://postgres:change-me-postgres-password@postgres:5432/online_judge
REDIS_PASSWORD=change-me-redis-password

JWT_SECRET=replace-with-32-byte-or-longer-random-secret
WORKER_SECRET=replace-with-independent-32-byte-or-longer-random-secret

# Public self-registration scope. The organization must exist before students register.
PUBLIC_REGISTRATION_ORGANIZATION_ID=1
PUBLIC_REGISTRATION_CAMPUS_ID=
PUBLIC_REGISTRATION_GRADE_ID=
